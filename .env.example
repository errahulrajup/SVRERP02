# ─────────────────────────────────────────────────────────────────
#  Srivriddhi — Environment Variables
#  Copy this file to .env and fill in your values
#  NEVER commit .env to git
# ─────────────────────────────────────────────────────────────────

# ── Supabase (Website CMS + Blog + Admin Panel)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ── Sentry (Error Monitoring — required in production)
VITE_SENTRY_DSN=https://your-sentry-dsn@sentry.io/your-project-id

# ── EmailJS (Contact Form)
VITE_EMAILJS_SERVICE_ID=your-service-id
VITE_EMAILJS_TEMPLATE_ID=your-template-id
VITE_EMAILJS_PUBLIC_KEY=your-public-key

# ── Business OS (BOS) Runtime Config
# Create public/svr-env.js from public/svr-env.example.js
# public/svr-env.js is in .gitignore — never commit it
