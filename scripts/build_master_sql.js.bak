import fs from 'fs';
import path from 'path';
import { fileURLToPath } from 'url';

const __dirname = path.dirname(fileURLToPath(import.meta.url));
const supabaseDir = path.join(__dirname, '..', 'supabase');

const filesToInclude = [
  'schema.sql',
  'erp_architecture.sql',
  'bos_schema.sql',
  'rnd_schema.sql',
  'bos_recipe_schema.sql',
  'bos_dms_schema.sql',
  'bos_security_hardening.sql',
  'maker_checker_workflow.sql',
  'auth_fix.sql'
];

let finalSql = `-- ============================================================
-- THE ULTIMATE MASTER RESET SCRIPT
-- Drops EVERYTHING and rebuilds the entire Srivriddhi ERP DB
-- ============================================================

DROP SCHEMA IF EXISTS public CASCADE;
CREATE SCHEMA public;

-- Drop new ERP schemas if they exist so we start fresh
DROP SCHEMA IF EXISTS iam CASCADE;
DROP SCHEMA IF EXISTS md CASCADE;
DROP SCHEMA IF EXISTS recipe CASCADE;
DROP SCHEMA IF EXISTS inv CASCADE;
DROP SCHEMA IF EXISTS mfg CASCADE;
DROP SCHEMA IF EXISTS qa CASCADE;
DROP SCHEMA IF EXISTS fin CASCADE;
DROP SCHEMA IF EXISTS cms CASCADE;
DROP SCHEMA IF EXISTS dms CASCADE;
DROP SCHEMA IF EXISTS log CASCADE;

GRANT ALL ON SCHEMA public TO postgres;
GRANT ALL ON SCHEMA public TO anon;
GRANT ALL ON SCHEMA public TO authenticated;
GRANT ALL ON SCHEMA public TO service_role;

`;

for (const file of filesToInclude) {
  try {
    const filePath = path.join(supabaseDir, file);
    const content = fs.readFileSync(filePath, 'utf8');
    finalSql += `\n\n-- ============================================================\n`;
    finalSql += `-- INJECTED FILE: ${file}\n`;
    finalSql += `-- ============================================================\n\n`;
    finalSql += content;
  } catch (err) {
    console.error(`Skipping missing file: ${file}`);
  }
}

// Add the final permissions loop at the end
finalSql += `
-- ============================================================
-- GLOBAL PERMISSIONS FIX
-- Grants read/write to authenticated for all tables in public
-- ============================================================
DO $$
DECLARE
  r RECORD;
BEGIN
  FOR r IN (SELECT tablename FROM pg_tables WHERE schemaname = 'public') LOOP
    EXECUTE 'GRANT ALL ON TABLE public.' || quote_ident(r.tablename) || ' TO authenticated;';
    EXECUTE 'GRANT ALL ON TABLE public.' || quote_ident(r.tablename) || ' TO anon;';
    EXECUTE 'GRANT ALL ON TABLE public.' || quote_ident(r.tablename) || ' TO service_role;';
  END LOOP;
END $$;
`;

fs.writeFileSync(path.join(supabaseDir, 'MASTER_DB_RESET.sql'), finalSql, 'utf8');
console.log('Successfully created MASTER_DB_RESET.sql');
